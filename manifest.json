{
    "manifest_version": 3,
    "name": "UI Inspector",
    "version": "1.0.0",
    "description": "A QA annotation tool for frontend developers",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "unlimitedStorage"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "html2canvas.min.js",
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}